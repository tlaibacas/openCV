{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],

    "skipLibCheck": true,
    "removeComments": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,

    "sourceMap": false,
    "declaration": false,
  },
  "exclude": ["prisma.config.ts"],
}
