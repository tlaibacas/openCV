generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  name      String?
  lastName  String?
  sex       Sex?
  role      Role     @default(visitor)
  agency    String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

enum Sex {
  male
  female
  other
}

enum Role {
  visitor
  admin
  recruiter
}
